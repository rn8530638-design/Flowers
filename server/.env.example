# Copy this file to `.env` and adjust as needed. All values are optional — the app
# runs with sensible defaults out of the box for a first deploy.
#
#   cp .env.example .env
#
# Hosting platforms that inject env vars directly (Railway, Render, a VPS with
# systemd, etc.) don't need a `.env` file at all — just set these in the platform's
# environment settings instead.

# "production" enables secure cookies and serves the built client/dist frontend.
# Leave unset (or "development") for local dev with the Vite dev server.
NODE_ENV=production

# Port the Express server listens on.
PORT=4000

# Secret used to sign the login session (JWT). CHANGE THIS to a long random string
# before a real deploy — anyone with this value can forge admin sessions.
JWT_SECRET=change-me-to-a-long-random-string

# Where the SQLite database file and uploaded flower photos live. Both the file and
# the folder are created automatically on first run if they don't exist — only set
# these if you want them somewhere other than inside server/ (e.g. a mounted volume).
# DB_PATH=/data/db.sqlite
# UPLOAD_DIR=/data/uploads

# First admin account, created by `npm run seed` (only if no admin exists yet).
# Change these before running the site publicly.
ADMIN_USER=admin
ADMIN_PASS=admin
